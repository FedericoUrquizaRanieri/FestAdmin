generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model conversations {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at   DateTime             @default(now()) @db.Timestamptz(6)
  phone_number String               @default("")
  buffer       String?              @default("")
  summary      String?              @default("")
  state        ConversationState?
  last_message DateTime?            @default(now()) @db.Timestamptz(6)
  pending      Boolean?
  control_over ConversarionControl?
  messages     messages[]
  purchases    purchases[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model events {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at DateTime    @default(now()) @db.Timestamptz(6)
  date       DateTime?   @db.Date
  name       String?     @default("")
  location   String?     @default("")
  expenses   expenses[]
  purchases  purchases[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model expenses {
  id          BigInt   @id @default(autoincrement())
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  event_id    String   @db.Uuid
  description String?
  amount      BigInt?
  events      events   @relation(fields: [event_id], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model messages {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at      DateTime       @default(now()) @db.Timestamptz(6)
  content         String?
  conversation_id String?        @db.Uuid
  conversations   conversations? @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model purchases {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  buyer_phone     String?         @default("")
  total_amount    BigInt?
  paid_amount     BigInt?
  state           PurchaseState?
  conversation_id String?         @db.Uuid
  event_id        String?         @db.Uuid
  conversations   conversations?  @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  events          events?         @relation(fields: [event_id], references: [id], onDelete: Cascade)
  tickets         tickets[]
  transfer_auth   transfer_auth[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model tickets {
  id            BigInt        @id @default(autoincrement())
  created_at    DateTime      @default(now()) @db.Timestamptz(6)
  first_name    String?
  last_name     String?
  number_assoc  String?
  payment_state Boolean?
  gender        GenderStruct?
  price         BigInt?
  checked_in    DateTime?     @db.Timestamptz(6)
  purchase_id   String?       @db.Uuid
  purchases     purchases?    @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model transfer_auth {
  id           BigInt         @id @default(autoincrement())
  created_at   DateTime       @default(now()) @db.Timestamptz(6)
  phone_number String?        @default("")
  storage_path String?        @default("")
  state        TransferState?
  purchase_id  String?        @db.Uuid
  purchases    purchases?     @relation(fields: [purchase_id], references: [id], onDelete: Cascade)
}

enum ConversarionControl {
  AI
  HUMAN
}

enum ConversationState {
  IDLE
  WAITING_PAYMENT
  WAITING_CONFIRMATION
  COMPLETED
}

enum GenderStruct {
  MALE
  FEMALE
}

enum PurchaseState {
  PENDING
  PAID
  PARTIALLY_PAID
  CANCELLED
  REFUNDED
}

enum TransferState {
  UNDER_REVIEW
  APPROVED
  REJECTED
}
